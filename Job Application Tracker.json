    {
      "parameters": {
        "jsCode": "const job = $input.item.json;\n\n// Strip HTML tags from description\nconst cleanDesc = (job.description || '')\n  .replace(/<[^>]*>/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .replace(/[^\\x20-\\x7E]/g, '')\n  .trim()\n  .substring(0, 800);\n\nconst skills = job.skills.map(s => s.skill).join(', ');\nconst company = (job.postedCompany?.name || 'Unknown').replace(/\"/g, '');\nconst title = (job.title || '').replace(/\"/g, '');\nconst salaryMin = job.salary?.minimum || 0;\nconst salaryMax = job.salary?.maximum || 0;\nconst minExp = job.minimumYearsExperience || 0;\n\n// Build the complete API request body as a proper object\nconst requestBody = {\n  model: \"claude-sonnet-4-5\",\n  max_tokens: 1024,\n  messages: [\n    {\n      role: \"user\",\n      content: `You are a job fit analyser. Score this job and return ONLY valid JSON with no markdown fences.\\n\\nCANDIDATE: Python, SQL, n8n workflow automation, Claude API, multi-agent systems, prompt engineering, ESG data domain expertise, prefers backend independent work and building automation tools, avoids heavy presentations and stakeholder management, minimum acceptable salary SGD 3500, has 5+ years ops/data experience so entry requirements under 5 years are fine.\\n\\nJOB: Title: ${title}, Company: ${company}, Salary: SGD ${salaryMin}-${salaryMax}, Min Experience: ${minExp} years, Skills: ${skills}, Description: ${cleanDesc}\\n\\nReturn ONLY: {\"fit_score\":<1-10>,\"salary_range\":\"SGD ${salaryMin}-${salaryMax}\",\"missing_skills\":\"<list or None>\",\"red_flags\":\"<concerns or None>\",\"ai_summary\":\"<2 sentences>\"}`\n    }\n  ]\n};\n\nreturn {\n  json: {\n    ...job,\n    request_body: requestBody\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1232,
        112
      ],
      "id": "aa77dbb4-70da-4ad1-96ab-0c2334a6bdd4",
      "name": "Build Prompt"
    },
