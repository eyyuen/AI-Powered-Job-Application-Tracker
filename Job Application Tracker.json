    {
      "parameters": {
        "jsCode": "const records = $input.all().slice(0, 10);\n\nif (records.length === 0) {\n  return {\n    json: {\n      subject: \"Job Tracker: No new Hot Leads today\",\n      body: \"<p>No jobs scored 7 or above today. Check back tomorrow!</p>\"\n    }\n  };\n}\n\nlet rows = '';\nfor (const record of records) {\n  const f = record.json.fields;\n  rows += `\n    <tr>\n      <td style=\"padding:8px;border:1px solid #e5e7eb;\">\n        <a href=\"${f.url}\" style=\"color:#1D4ED8;font-weight:bold;\">\n          ${f.job_title}\n        </a>\n      </td>\n      <td style=\"padding:8px;border:1px solid #e5e7eb;\">${f.company}</td>\n      <td style=\"padding:8px;border:1px solid #e5e7eb;text-align:center;\">\n        <strong style=\"color:#166534;\">${f.fit_score}/10</strong>\n      </td>\n      <td style=\"padding:8px;border:1px solid #e5e7eb;\">${f.salary_range}</td>\n      <td style=\"padding:8px;border:1px solid #e5e7eb;color:#6B7280;font-size:13px;\">\n        ${f.ai_summary}\n      </td>\n    </tr>\n  `;\n}\n\nconst body = `\n<div style=\"font-family:Arial,sans-serif;max-width:900px;margin:0 auto;\">\n  <div style=\"background:#1F2937;padding:24px;border-radius:8px 8px 0 0;\">\n    <h1 style=\"color:white;margin:0;font-size:22px;\">\n      🎯 Daily Job Digest\n    </h1>\n    <p style=\"color:#9CA3AF;margin:8px 0 0;\">\n      ${records.length} Hot Lead${records.length > 1 ? 's' : ''} found today · ${new Date().toDateString()}\n    </p>\n  </div>\n  <div style=\"padding:24px;background:#F9FAFB;border-radius:0 0 8px 8px;\">\n    <table style=\"width:100%;border-collapse:collapse;background:white;border-radius:8px;overflow:hidden;\">\n      <thead>\n        <tr style=\"background:#1D4ED8;color:white;\">\n          <th style=\"padding:10px 8px;text-align:left;\">Role</th>\n          <th style=\"padding:10px 8px;text-align:left;\">Company</th>\n          <th style=\"padding:10px 8px;text-align:center;\">Score</th>\n          <th style=\"padding:10px 8px;text-align:left;\">Salary</th>\n          <th style=\"padding:10px 8px;text-align:left;\">AI Summary</th>\n        </tr>\n      </thead>\n      <tbody>${rows}</tbody>\n    </table>\n    <p style=\"color:#6B7280;font-size:13px;margin-top:16px;\">\n      View full details and update status in \n      <a href=\"https://airtable.com\" style=\"color:#1D4ED8;\">Airtable</a>\n    </p>\n  </div>\n</div>\n`;\n\nreturn {\n  json: {\n    subject: `🎯 ${records.length} New Job Lead${records.length > 1 ? 's' : ''} Today — ${new Date().toDateString()}`,\n    body: body\n  }\n};"
      },
