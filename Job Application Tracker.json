    {
      "parameters": {
        "jsCode": "const content = $input.item.json.content[0].text;\n\n// Remove markdown fences if present\nlet cleaned = content.trim();\nif (cleaned.startsWith(\"```\")) {\n  cleaned = cleaned.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n}\n\n// Parse the JSON\nconst parsed = JSON.parse(cleaned);\n\n// Merge with original job data from two steps back\nconst jobData = $('Loop Over Items').item.json;\n\nreturn {\n  json: {\n    job_title: jobData.title,\n    company: jobData.postedCompany?.name || 'Unknown',\n    url: jobData.metadata?.jobDetailsUrl || '',\n    platform: 'MyCareersFuture',\n    date_found: new Date().toISOString().split('T')[0],\n    fit_score: parsed.fit_score,\n    salary_range: parsed.salary_range,\n    missing_skills: parsed.missing_skills,\n    red_flags: parsed.red_flags,\n    ai_summary: parsed.ai_summary\n  }\n};"
      },
